// For backward compatibility.
#include <mongocxx/v1/config/config.hpp> // IWYU pragma: export

#if !defined(MONGOCXX_ENABLE_UNSTABLE_ABI)
#cmakedefine01 MONGOCXX_ENABLE_UNSTABLE_ABI
#endif

#if MONGOCXX_ENABLE_UNSTABLE_ABI == 1
#define MONGOCXX_ABI_EXPORT_UNSTABLE MONGOCXX_ABI_EXPORT
#else
#define MONGOCXX_ABI_EXPORT_UNSTABLE MONGOCXX_ABI_NO_EXPORT
#endif

#define MONGOCXX_ABI_EXPORT_CDECL_UNSTABLE(...) MONGOCXX_ABI_EXPORT_UNSTABLE __VA_ARGS__ MONGOCXX_ABI_CDECL

///
/// @file
/// Provides macros describing the mongocxx (v_noabi) library configuration.
///
/// @par Includes
/// - @ref mongocxx/v1/config/config.hpp
///

///
/// @def MONGOCXX_ENABLE_UNSTABLE_ABI
/// @hideinitializer
/// Controls whether unstable ABI symbols are exported by the shared library.
///
/// @warning For internal use only!
///

///
/// @def MONGOCXX_ABI_EXPORT_UNSTABLE
/// @hideinitializer
/// Exports the associated entity as part of the unstable ABI.
///
/// @warning For internal use only!
///

///
/// @def MONGOCXX_ABI_EXPORT_CDECL_UNSTABLE
/// @hideinitializer
/// Equivalent to @ref MONGOCXX_ABI_EXPORT_UNSTABLE with @ref MONGOCXX_ABI_CDECL.
///
/// @warning For internal use only!
///
